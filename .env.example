# ─── Band/Thenvoi Platform ───────────────────────────────────────────────────
BAND_API_KEY=your_band_api_key_here

# Per-agent credentials — create each at https://app.thenvoi.com
# Go to: Your workspace → Agents → Create Agent → copy UUID + API key
PLANNER_AGENT_ID=
PLANNER_AGENT_API_KEY=
HR_POLICY_AGENT_ID=
HR_POLICY_AGENT_API_KEY=
IT_PROVISIONING_AGENT_ID=
IT_PROVISIONING_AGENT_API_KEY=
MANAGER_REVIEW_AGENT_ID=
MANAGER_REVIEW_AGENT_API_KEY=

# ─── AI/ML API (Secondary LLM) ────────────────────────────────────────────────
AIML_API_KEY=your_aimlapi_key_here
AIML_BASE_URL=https://api.aimlapi.com/v1

# ─── Featherless AI (Primary — confirmed working open-source models) ──────────
FEATHERLESS_API_KEY=your_featherless_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ─── OpenAI (Optional fallback) ───────────────────────────────────────────────
OPENAI_API_KEY=

# ─── LLM Provider Selection ───────────────────────────────────────────────────
PRIMARY_LLM_PROVIDER=featherless  # "featherless" or "aimlapi"

# ─── Models ───────────────────────────────────────────────────────────────────
PLANNER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
HR_POLICY_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
IT_PROVISIONING_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
MANAGER_REVIEW_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
DEMO_MODE=true
