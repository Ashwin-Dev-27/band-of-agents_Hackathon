# ─── Band Platform ───────────────────────────────────────────────────────────
BAND_API_KEY=your_band_api_key_here
BAND_AGENT_ID=your_band_agent_id_here

# ─── AI/ML API (Primary LLM — $10 credits from hackathon) ───────────────────
AIML_API_KEY=your_aimlapi_key_here
AIML_BASE_URL=https://api.aimlapi.com/v1

# ─── Featherless AI (Open-source models — $25 credits from hackathon) ────────
FEATHERLESS_API_KEY=your_featherless_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ─── OpenAI (Fallback if needed) ─────────────────────────────────────────────
OPENAI_API_KEY=optional_openai_key

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ─── Models to Use ────────────────────────────────────────────────────────────
PLANNER_MODEL=gpt-4o
HR_POLICY_MODEL=gpt-4o-mini
IT_PROVISIONING_MODEL=gpt-4o-mini
MANAGER_REVIEW_MODEL=gpt-4o
